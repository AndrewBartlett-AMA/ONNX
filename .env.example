# Frontend ASR configuration. Vite exposes client-side variables with the VITE_ prefix.
VITE_ASR_PROVIDER=local-websocket
VITE_ASR_MODEL=granite-4.0-1b-speech
VITE_ASR_WEBSOCKET_URL=ws://localhost:8765/asr
VITE_ASR_SAMPLE_RATE=16000
VITE_ASR_ENABLE_PARTIALS=true

# Equivalent names for local ASR services or non-Vite tooling.
ASR_PROVIDER=local-websocket
ASR_MODEL=granite-4.0-1b-speech
ASR_WEBSOCKET_URL=ws://localhost:8765/asr
ASR_SAMPLE_RATE=16000
ASR_ENABLE_PARTIALS=true

# Reserved for non-ASR OpenAI reasoning, chat, or summarisation features if added later.
OPENAI_MODEL=gpt-5.5
